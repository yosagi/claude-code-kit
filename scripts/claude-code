#!/bin/bash
# claude-code launcher with osc-tap logging
#
# osc-tap 経由で claude を起動し、OSC シーケンスをキャプチャする。
# セッションログのエクスポートやタイトル取得に利用される。
# osc-tap が PATH に無い場合は素の claude を直接起動する。
#
# 起動時に ~/Notes/claude-registry/dist/.dist-stamp が更新されていたら
# setup_global.sh --install を自動実行する（auto-install）。
#
# CLAUDE.md / CLAUDE.local.md がなければ dist から自動配置、
# 更新があれば対話的に確認する。.no-claude-md-sync を置くと同期しない。
#
# 起動時に reports/project_title.txt があれば表示する。
# ログ出力先: ~/.claude/osc-logs/
#
# Wrapper options:
#   --list-versions            インストール済み Claude Code バージョン一覧
#   --enforce-version VERSION  指定バージョンで起動（回帰回避用）
#   --no-osc-tap               osc-tap をバイパスして素の claude を起動
#   --help                     wrapper ヘルプ + claude --help
#
# stdout が TTY でないときは osc-tap を自動バイパスする（systemd service など）。

VERSIONS_DIR="${HOME}/.local/share/claude/versions"
CLAUDE_SYMLINK="${HOME}/.local/bin/claude"
LOG_DIR="${HOME}/.claude/osc-logs"

# Versions to avoid on default launch. If the active version (as pointed to by
# the claude symlink) appears here, the wrapper falls back to the highest
# non-blacklisted version installed. --enforce-version bypasses this check.
VERSION_BLACKLIST=(
    "2.1.117"
)

print_wrapper_help() {
    cat <<'EOF'
claude-code wrapper (osc-tap logging + version management)

Wrapper-specific options:
  --list-versions            List installed Claude Code versions
  --enforce-version VERSION  Launch a specific version (e.g. 2.1.116)
                             Useful to pin around a buggy release.
  --no-osc-tap               Bypass osc-tap and exec claude directly.
                             Auto-enabled when stdout is not a TTY
                             (e.g. systemd service, CI, piped output).

Versions listed in VERSION_BLACKLIST (near the top of this script) are
auto-avoided on default launch: the highest non-blacklisted version is
used instead. --enforce-version bypasses the blacklist.

Auto-install: if ~/Notes/claude-registry/dist/.dist-stamp differs from
~/.claude/.dist-stamp, setup_global.sh --install runs automatically
before launching claude. Output is logged to ~/.claude/auto-install.log.

Other options are passed through to claude.
Below is the underlying `claude --help` output:

---
EOF
}

is_blacklisted() {
    local v="$1"
    local b
    for b in "${VERSION_BLACKLIST[@]}"; do
        [[ "$v" == "$b" ]] && return 0
    done
    return 1
}

pick_fallback_version() {
    # Highest non-blacklisted installed version (empty if none).
    local candidates=()
    local v name
    for v in "$VERSIONS_DIR"/*; do
        [[ -x "$v" ]] || continue
        name="$(basename "$v")"
        is_blacklisted "$name" && continue
        candidates+=("$name")
    done
    (( ${#candidates[@]} == 0 )) && return 0
    printf '%s\n' "${candidates[@]}" | sort -V | tail -1
}

list_versions() {
    local current_target=""
    if [[ -L "$CLAUDE_SYMLINK" ]]; then
        current_target="$(readlink -f "$CLAUDE_SYMLINK" 2>/dev/null)"
    fi
    echo "Installed versions (in $VERSIONS_DIR):"
    local found=0
    for v in "$VERSIONS_DIR"/*; do
        [[ -x "$v" ]] || continue
        found=1
        local name markers
        name="$(basename "$v")"
        markers=""
        [[ "$v" == "$current_target" ]] && markers="current"
        if is_blacklisted "$name"; then
            markers="${markers:+$markers, }blacklisted"
        fi
        if [[ -n "$markers" ]]; then
            printf "  %s  (%s)\n" "$name" "$markers"
        else
            printf "  %s\n" "$name"
        fi
    done
    if (( ! found )); then
        echo "  (none)"
    fi
}

# Parse wrapper-specific flags (preserve order of passthrough args)
enforced_version=""
show_list=0
show_help=0
no_osc_tap=0
passthrough_args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --list-versions)
            show_list=1
            shift
            ;;
        --enforce-version)
            if [[ $# -lt 2 ]]; then
                echo "claude-code: --enforce-version requires a value" >&2
                exit 2
            fi
            enforced_version="$2"
            shift 2
            ;;
        --enforce-version=*)
            enforced_version="${1#--enforce-version=}"
            shift
            ;;
        --no-osc-tap)
            no_osc_tap=1
            shift
            ;;
        --help|-h)
            show_help=1
            passthrough_args+=("$1")
            shift
            ;;
        *)
            passthrough_args+=("$1")
            shift
            ;;
    esac
done

# Auto-bypass osc-tap when stdout is not a TTY (headless / piped).
if [[ ! -t 1 ]]; then
    no_osc_tap=1
fi

# Auto-install: if registry dist has a newer stamp, run setup_global.sh --install.
REGISTRY_DIST="$HOME/Notes/claude-registry/dist"
REGISTRY_STAMP="$REGISTRY_DIST/.dist-stamp"
LOCAL_STAMP="$HOME/.claude/.dist-stamp"

maybe_auto_install() {
    [[ -f "$REGISTRY_STAMP" ]] || return 0
    local registry_stamp local_stamp
    registry_stamp="$(cat "$REGISTRY_STAMP" 2>/dev/null)" || return 0
    local_stamp="$(cat "$LOCAL_STAMP" 2>/dev/null)"
    [[ "$registry_stamp" == "$local_stamp" ]] && return 0

    local log_file="$HOME/.claude/auto-install.log"
    echo "claude-code: dist updated, auto-installing..." >&2
    if "$REGISTRY_DIST/setup_global.sh" --install > "$log_file" 2>&1; then
        mkdir -p "$(dirname "$LOCAL_STAMP")"
        cp "$REGISTRY_STAMP" "$LOCAL_STAMP"
        echo "claude-code: auto-install complete (log: $log_file)" >&2
    else
        echo "claude-code: auto-install failed (log: $log_file)" >&2
    fi
}
maybe_auto_install

# CLAUDE.md / CLAUDE.local.md sync: deploy dist templates to project root.
NO_SYNC_MARKER=".no-claude-md-sync"

maybe_sync_claude_md() {
    [[ -d "$REGISTRY_DIST" ]] || return 0
    local project_root
    project_root="$(git rev-parse --show-toplevel 2>/dev/null)" || project_root="$(pwd)"
    [[ -f "$project_root/$NO_SYNC_MARKER" ]] && return 0

    local need_update=()
    for f in CLAUDE.md CLAUDE.local.md; do
        local src="$REGISTRY_DIST/$f"
        [[ -f "$src" ]] || continue
        if [[ ! -f "$project_root/$f" ]]; then
            cp "$src" "$project_root/$f"
            echo "claude-code: $f を配置しました" >&2
        elif ! diff -q "$src" "$project_root/$f" > /dev/null 2>&1; then
            need_update+=("$f")
        fi
    done

    if (( ${#need_update[@]} > 0 )); then
        echo "claude-code: ${need_update[*]} に更新があります" >&2
        read -p "更新しますか? [y/N] " answer < /dev/tty
        if [[ "$answer" =~ ^[yY] ]]; then
            for f in "${need_update[@]}"; do
                cp "$REGISTRY_DIST/$f" "$project_root/$f"
            done
            echo "claude-code: 更新しました" >&2
        fi
    fi
}
maybe_sync_claude_md

# --list-versions: print and exit
if (( show_list )); then
    list_versions
    exit 0
fi

# Resolve which claude binary to use
claude_bin="claude"
if [[ -n "$enforced_version" ]]; then
    candidate="$VERSIONS_DIR/$enforced_version"
    if [[ ! -x "$candidate" ]]; then
        echo "claude-code: version '$enforced_version' not found in $VERSIONS_DIR" >&2
        echo "" >&2
        list_versions >&2
        exit 1
    fi
    claude_bin="$candidate"
elif (( ${#VERSION_BLACKLIST[@]} > 0 )) && [[ -L "$CLAUDE_SYMLINK" ]]; then
    current_target="$(readlink -f "$CLAUDE_SYMLINK" 2>/dev/null)"
    current_version="$(basename "$current_target")"
    if is_blacklisted "$current_version"; then
        fallback="$(pick_fallback_version)"
        if [[ -z "$fallback" ]]; then
            echo "claude-code: active version '$current_version' is blacklisted and no alternative is available in $VERSIONS_DIR" >&2
            echo "            override with --enforce-version $current_version" >&2
            exit 1
        fi
        echo "claude-code: active version '$current_version' is blacklisted; falling back to '$fallback'" >&2
        claude_bin="$VERSIONS_DIR/$fallback"
    fi
fi

# --help intercept: print wrapper help first, then delegate to claude --help
if (( show_help )); then
    print_wrapper_help
fi

# プロジェクトタイトルの表示（--help 時はスキップ）
if (( ! show_help )); then
    TITLE_FILE="reports/project_title.txt"
    if [[ -f "$TITLE_FILE" ]]; then
        printf '\033[36m%s\033[0m\n' "$(cat "$TITLE_FILE")"
    fi
fi

if (( no_osc_tap )) || ! command -v osc-tap >/dev/null 2>&1; then
    # --no-osc-tap 指定時、非TTY環境、osc-tap が無い環境は素の claude を起動する。
    exec "$claude_bin" "${passthrough_args[@]}"
else
    exec osc-tap \
        --output "$LOG_DIR" \
        --matcher TITLE '0;(.*)' \
        --matcher TRANSCRIPT '10321;TRANSCRIPT=(.*)' \
        --matcher CWD '10321;CWD=(.*)' \
        --matcher SESSION_ID '10321;SESSION_ID=(.*)' \
        -- "$claude_bin" "${passthrough_args[@]}"
fi
